# ──────────────────────────────────────────────────────────────
# VaultDrop Scraper – Environment Variables
# ──────────────────────────────────────────────────────────────

# Reddit – uses public RSS feeds (no credentials needed).
# The scrapers fetch .rss Atom feeds directly from reddit.com.
# No REDDIT_CLIENT_ID or REDDIT_CLIENT_SECRET is required.

# ── Optional: AI caption service ──────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Optional: Database ────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@localhost:5432/vaultdrop

# ── Optional: Scraping config ─────────────────────────────────
# RATE_LIMIT_SECONDS=2
# REQUEST_TIMEOUT=30
